# infra-home environment configuration
#
# Copy this file to `.env` and fill in your values. The .env file is
# gitignored and never committed.

# ----- Pi-hole admin (used by scripts/update_status.sh) ----------------------
PIHOLE_PASSWORD=your_pihole_password_here

# ----- Hue Bridge (LAN-only) -------------------------------------------------
# IP and pairing token for your Hue Bridge. Pair via the physical bridge
# button + curl -X POST 'http://<bridge-ip>/api' -d '{"devicetype":"infra-home"}'
HUE_BRIDGE=192.168.1.50
HUE_TOKEN=your_hue_pairing_token_here

# ----- Network device IPs ----------------------------------------------------
# Set these to your local IP assignments. Defaults below are placeholders.
TV_IP=192.168.1.51
GPU_TOWER_IP=192.168.1.52
FIRESTICK_IP=192.168.1.53
LIVEBOX_IP=192.168.1.1
GOVEE_IP=192.168.1.54
PIHOLE_IP=192.168.1.55
